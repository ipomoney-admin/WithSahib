# ─────────────────────────────────────────────────────────────────────────────
# withSahib — Environment Variables
# Copy this file to .env.local and fill in your values.
# Ask Sahib for development credentials.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Settings → API
# NEXT_PUBLIC_* keys are safe to expose to the browser
# SUPABASE_SERVICE_ROLE_KEY is server-only — NEVER ship to browser
NEXT_PUBLIC_SUPABASE_URL=https://[your-project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon key — safe for browser]
SUPABASE_SERVICE_ROLE_KEY=[service role key — server only, never expose]

# ─── APP ─────────────────────────────────────────────────────────────────────
# Use http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=withSahib

# ─── RAZORPAY ────────────────────────────────────────────────────────────────
# Get from: Razorpay dashboard → Settings → API Keys
# Use test keys (rzp_test_*) for local dev
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Razorpay Plan IDs (create in Razorpay dashboard → Subscriptions → Plans)
# See README.md for plan amounts and billing cycles
NEXT_PUBLIC_RAZORPAY_PLAN_BASIC_MONTHLY=plan_xxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_PLAN_BASIC_YEARLY=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_BASIC_MONTHLY=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_BASIC_YEARLY=plan_xxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_PLAN_PRO_MONTHLY=plan_xxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_PLAN_PRO_YEARLY=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_PRO_MONTHLY=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_PRO_YEARLY=plan_xxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_PLAN_ELITE_MONTHLY=plan_xxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_PLAN_ELITE_YEARLY=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_ELITE_MONTHLY=plan_xxxxxxxxxxxx
RAZORPAY_PLAN_ELITE_YEARLY=plan_xxxxxxxxxxxx

# ─── RESEND (email) ──────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@withsahib.com

# ─── ANTHROPIC (AI intelligence reports) ─────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ─── FYERS (market data + screener) ──────────────────────────────────────────
# Get from: myapi.fyers.in → My Apps
# FYERS_REDIRECT_URI must match exactly what's set in Fyers app settings
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=https://www.withsahib.com/api/fyers/callback
FYERS_MPIN=           # Used for automated token refresh

# ─── AISENSY (WhatsApp delivery) ─────────────────────────────────────────────
# Get from: AiSensy dashboard → API
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=

# ─── TELEGRAM (admin alerts) ─────────────────────────────────────────────────
# Create a bot via @BotFather, get chat IDs from @userinfobot
TELEGRAM_BOT_TOKEN=
SAHIB_TELEGRAM_ID=          # Sahib's personal chat ID (for critical alerts)
TELEGRAM_PAID_CHANNEL_ID=   # Channel for paid subscribers
TELEGRAM_FREE_CHANNEL_ID=   # Channel for free subscribers

# ─── CRON PROTECTION ─────────────────────────────────────────────────────────
# Random secret — used to authenticate Vercel cron job calls
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── ANTHROPIC (blog draft automation) ───────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── RAZORPAY (subscription payments) ────────────────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── SITE URL (used internally for API self-calls) ────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.withsahib.com
